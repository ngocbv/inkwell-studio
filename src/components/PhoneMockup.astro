---
interface Props {
  screenshot?: string;
  alt?: string;
  tilt?: boolean;
  float?: boolean;
  transitionName?: string;
  placeholder?: string;
}

const {
  screenshot,
  alt = 'App screenshot',
  tilt = false,
  float: shouldFloat = false,
  transitionName,
  placeholder = 'SecureDiary',
} = Astro.props;

const classes = [
  'phone',
  tilt && 'phone-tilt',
  shouldFloat && 'phone-float',
  'parallax',
].filter(Boolean);
---

<div
  class:list={classes}
  transition:name={transitionName}
>
  <div class="phone__frame">
    <div class="phone__notch"></div>
    <div class="phone__screen">
      {screenshot ? (
        <img src={screenshot} alt={alt} loading="lazy" class="phone__screenshot" />
      ) : (
        <div class="phone__placeholder">
          <span>{placeholder}</span>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .phone {
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
  }

  .phone__frame {
    position: relative;
    background: #1a1a1a;
    border-radius: 36px;
    padding: 12px;
    box-shadow: var(--shadow), inset 0 0 0 2px rgba(255,255,255,0.1);
    transition: box-shadow 0.3s ease;
  }

  .phone-tilt:hover .phone__frame {
    box-shadow: var(--shadow-hover), inset 0 0 0 2px rgba(255,255,255,0.1);
  }

  .phone__notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 24px;
    background: #1a1a1a;
    border-radius: 0 0 16px 16px;
    z-index: 2;
  }

  .phone__screen {
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 9 / 19.5;
    background: var(--color-bg);
  }

  .phone__screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phone__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-bg) 0%, #F5EBE0 100%);
  }

  .phone__placeholder span {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .phone {
      max-width: 220px;
    }
  }
</style>
