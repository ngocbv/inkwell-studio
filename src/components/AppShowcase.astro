---
import PhoneMockup from './PhoneMockup.astro';
import ScrollReveal from './ScrollReveal.astro';

interface Props {
  name: string;
  tagline: string;
  features: string[];
  accentColor: string;
  icon?: string;
  screenshot?: string;
  link?: string | null;
  reverse?: boolean;
  transitionName?: string;
}

const {
  name,
  tagline,
  features,
  accentColor,
  icon,
  screenshot,
  link = null,
  reverse = false,
  transitionName,
} = Astro.props;

const bgGradient = reverse
  ? `linear-gradient(225deg, ${accentColor}12 0%, var(--color-bg) 100%)`
  : `linear-gradient(135deg, ${accentColor}12 0%, var(--color-bg) 100%)`;
---

<section class:list={['showcase', reverse && 'showcase--reverse']} style={`background: ${bgGradient};`}>
  <div class="showcase__inner">
    <ScrollReveal class="showcase__text">
      {icon && <img src={icon} alt={`${name} icon`} class="showcase__icon" />}
      <h2 class="showcase__name">{name}</h2>
      <p class="showcase__tagline">{tagline}</p>
      <ul class="showcase__features">
        {features.map(f => <li>{f}</li>)}
      </ul>
      {link ? (
        <a href={link} class="showcase__link" style={`color: ${accentColor};`}>
          Learn more &rarr;
        </a>
      ) : (
        <span class="showcase__link showcase__link--muted">Coming soon</span>
      )}
    </ScrollReveal>

    <ScrollReveal delay={200} class="showcase__phone">
      <PhoneMockup
        screenshot={screenshot}
        alt={`${name} app screenshot`}
        tilt
        transitionName={transitionName}
        placeholder={name}
      />
    </ScrollReveal>
  </div>
</section>

<style>
  .showcase {
    padding: var(--section-padding) 0;
  }

  .showcase__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 64px;
  }

  .showcase--reverse .showcase__inner {
    flex-direction: row-reverse;
  }

  .showcase__text {
    flex: 1;
  }

  .showcase__phone {
    flex: 0 0 auto;
  }

  .showcase__icon {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    margin-bottom: 16px;
    box-shadow: var(--shadow);
  }

  .showcase__name {
    font-size: 2rem;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .showcase__tagline {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-bottom: 24px;
  }

  .showcase__features {
    margin-bottom: 24px;
  }

  .showcase__features li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 8px;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .showcase__features li::before {
    content: '·';
    position: absolute;
    left: 4px;
    font-weight: bold;
    font-size: 1.2em;
  }

  .showcase__link {
    font-size: 0.95rem;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  .showcase__link:hover { opacity: 0.7; }
  .showcase__link--muted {
    color: var(--color-text-secondary);
    cursor: default;
  }
  .showcase__link--muted:hover { opacity: 1; }

  @media (max-width: 768px) {
    .showcase__inner {
      flex-direction: column;
      gap: 32px;
    }
    .showcase--reverse .showcase__inner {
      flex-direction: column;
    }
  }
</style>
