---
---

<section id="security" class="security">
  <div class="security__inner">
    <div class="security__shimmer"></div>

    <svg class="security__icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#FFF8F0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
    </svg>

    <h2 class="security__title">AES-256 encrypted, on your device</h2>

    <div class="security__grid">
      <div class="security__item">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#C4856A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
        <h3>AES-256-GCM</h3>
        <p>Every entry encrypted with industry-standard algorithm</p>
      </div>

      <div class="security__item">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#C4856A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="1" y1="1" x2="23" y2="23" />
          <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55" />
          <path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39" />
          <path d="M10.71 5.05A16 16 0 0 1 22.56 9" />
          <path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88" />
          <path d="M8.53 16.11a6 6 0 0 1 6.95 0" />
          <line x1="12" y1="20" x2="12.01" y2="20" />
        </svg>
        <h3>Zero network access</h3>
        <p>No internet permission. Nothing is ever uploaded</p>
      </div>

      <div class="security__item">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#C4856A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" />
        </svg>
        <h3>Hardware-backed keys</h3>
        <p>Encryption keys stored in device secure enclave</p>
      </div>
    </div>
  </div>
</section>

<style>
  .security {
    background: var(--color-dark-bg);
    color: var(--color-dark-text);
    padding: var(--section-padding) 0;
    position: relative;
    overflow: hidden;
  }

  .security__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 248, 240, 0.03) 50%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: shimmer 3s ease-in-out infinite;
    pointer-events: none;
  }

  .security__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .security__icon {
    margin: 0 auto 16px;
    opacity: 0.9;
  }

  .security__title {
    font-size: 2rem;
    color: var(--color-dark-text);
    margin-bottom: 48px;
  }

  .security__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .security__item h3 {
    color: var(--color-dark-text);
    margin: 12px 0 8px;
    font-family: var(--font-heading);
    font-size: 1.1rem;
  }

  .security__item p {
    color: rgba(255, 248, 240, 0.6);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .security__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .security__title { font-size: 1.5rem; }
  }
</style>
