---
interface Props {
  headline?: string;
  playStoreUrl?: string;
  showAppStore?: boolean;
}

const {
  headline = 'Start your private journal',
  playStoreUrl = '#',
  showAppStore = true,
} = Astro.props;
---

<section id="download" class="cta">
  <div class="cta__inner">
    <h2 class="cta__title">{headline}</h2>

    <div class="cta__badges">
      <a href={playStoreUrl} class="cta__badge btn-primary" target="_blank" rel="noopener">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.394 12l2.304-2.492zM5.864 2.658L16.8 9.891l-2.302 2.302L5.864 2.658z"/>
        </svg>
        <div>
          <span class="cta__badge-label">Get it on</span>
          <span class="cta__badge-store">Google Play</span>
        </div>
      </a>

      {showAppStore && (
        <div class="cta__badge cta__badge--disabled">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div>
            <span class="cta__badge-label">Coming soon on</span>
            <span class="cta__badge-store">App Store</span>
          </div>
        </div>
      )}
    </div>

    <p class="cta__note">Free forever. No ads. No tracking.</p>
  </div>
</section>

<style>
  .cta {
    padding: var(--section-padding) 0;
    text-align: center;
  }

  .cta__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  .cta__title {
    font-size: 2rem;
    color: var(--color-text);
    margin-bottom: 32px;
  }

  .cta__badges {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .cta__badge {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    background: var(--color-dark-bg);
    color: var(--color-dark-text);
    border-radius: var(--radius-button);
    cursor: pointer;
    text-decoration: none;
  }

  .cta__badge--disabled {
    opacity: 0.4;
    cursor: default;
    position: relative;
  }

  .cta__badge-label {
    display: block;
    font-size: 0.7rem;
    opacity: 0.7;
  }

  .cta__badge-store {
    display: block;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .cta__note {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }
</style>
